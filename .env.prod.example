SERVER_HTTP_PORT=19090
SERVER_GRPC_PORT=6565
NODE_EXPORTER_HTTP_PORT=9100

CENTRAL_BACKEND_HOST=192.168.0.11
CENTRAL_BACKEND_HTTP_PORT=18080
